# ── Unity generated folders ────────────────────────────────────────────────────
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Unity cache & autogenerated files
*.pidb
*.suo
*.user
*.userprefs
*.unityproj
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
sysinfo.txt
*.stackdump
ExportedObj/
.consulo/

# ── SteamCMD output artifacts ─────────────────────────────────────────────────
# Auto-generated VDF scripts (recreated on each deploy run)
Assets/Editor/SteamDeployer/steamcmd_scripts/
steamcmd/scripts/
steamcmd/logs/
steamcmd/dumps/
steamcmd/appcache/
steamcmd/depotcache/
steamcmd/package/

# SteamCMD executable itself should not be committed
steamcmd.exe
steamcmd

# Steam build output (Unity Temp folder)
Temp/SteamUploadOutput/

# ── Credentials & secrets (NEVER commit these) ────────────────────────────────
# Just in case someone accidentally places password files here
*.password
*.secret
*.credentials
.env
.env.*
secrets.json
credentials.json

# ── OS generated files ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE & editor folders ───────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.sln
*.csproj

# ── Visual Studio cache/options ────────────────────────────────────────────────
.vs/
*.cache
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ── JetBrains Rider ────────────────────────────────────────────────────────────
.idea/

# ── Node / npm (if any tooling scripts are added later) ───────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
